# Halyard Fleet configuration.
# Copy to .env and fill in. Never commit .env.

# Where the control plane lives. This is the only place the address is written
# down: the service binds to it and the hook bridges derive their URL from it.
# Change the port here and everything follows.
#
# Keep the 127.0.0.1. This service decides whether commands may run on this
# machine; it has no business listening on a public interface. For remote
# access put Tailscale or WireGuard in front of it.
HALYARD_BIND=127.0.0.1:8787

# Three timeouts, and they must stay in this order:
#
#   approval  <  bridge  <  hook
#
# A hook that exceeds its timeout fails open — Claude Code discards it and runs
# the command. So every layer has to answer before the one above it gives up.
# The service refuses to start if this ordering is broken.
#
# How long an approval card stays answerable before it resolves as "deny".
HALYARD_APPROVAL_TIMEOUT_SECONDS=300
# How long bridge/hook_bridge.py waits on its HTTP call.
HALYARD_BRIDGE_TIMEOUT_SECONDS=330
# Must match the "timeout" on the hook in .claude/settings.json. Declared here
# so the ordering above can be checked; Claude Code does not read it from here.
HALYARD_HOOK_TIMEOUT_SECONDS=600

# Only needed when the control plane is somewhere else — another machine
# reached over Tailscale or WireGuard. Leave it unset otherwise: the bridges
# derive the address from HALYARD_BIND above, which is the only place it is
# written down.
#
# HALYARD_URL=http://100.x.y.z:8787

HALYARD_DB_PATH=./halyard.db
HALYARD_AUDIT_LOG=./audit.jsonl

# Which channel resolves approvals. Required, and left blank on purpose: two of
# these answer every request by themselves, and that must never be arrived at by
# copying a file and not reading this line. Pick one.
#   telegram    send a card and wait for a human
#   stub_allow  approve everything immediately, without asking (testing only)
#   stub_deny   deny everything immediately (testing only)
HALYARD_CHANNEL=

# Telegram channel adapter. Required when HALYARD_CHANNEL=telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Comma-separated Telegram user IDs allowed to resolve approvals.
# A callback from any other user is logged as unauthorized_callback and ignored.
TELEGRAM_AUTHORIZED_USER_IDS=

# Optional: give a navigator and a driver their own conversations, so two
# sessions on one codebase are not interleaved in a single chat.
#
# One bot is enough — a bot can be in many groups, it just cannot hold more
# than one private chat with you. Create two groups, add the same bot to
# both, and put their ids here. Each may also be a forum topic in a shared
# group: -1001234567890:12
#
# Leave both unset and everything goes to TELEGRAM_CHAT_ID as before. Which
# session is which is decided at launch:
#     HALYARD_ROLE=navigator claude
#     HALYARD_ROLE=driver    claude
# TELEGRAM_NAVIGATOR_CHAT_ID=
# TELEGRAM_DRIVER_CHAT_ID=

# Human-readable project name shown on approval cards.
CLAUDE_PROJECT_NAME=alpha-engine

# What a turn sent from a chat runs on, before anybody says /model.
#
# Not the CLI's own default, which is haiku — measured, not read. That is a
# reasonable default for a one-shot prompt and the wrong one for continuing
# work on a real codebase, and the difference shows up only in the quality of
# the answer, never in a message saying which model replied.
#
# Leave it empty to pass no --model at all and take whatever the CLI does.
HALYARD_CLAUDE_DEFAULT_MODEL=sonnet

# What /options offers under "model", comma separated. Only a suggestion — any
# name is still passed to the CLI — but it means a model released tomorrow can
# be offered by name today, without waiting for a release here.
# Unset uses the aliases the CLI documents: opus, sonnet, haiku, fable.
# HALYARD_CLAUDE_MODELS=opus,sonnet,haiku,fable
